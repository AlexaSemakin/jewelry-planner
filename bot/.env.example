BOT_TOKEN=ВСТАВЬ_СЮДА_ТОКЕН_БОТА
DATABASE_URL=sqlite+aiosqlite:///./plantcare.db

# ID закрытой группы с экспертом. Например: -1001234567890
# Чтобы узнать ID, добавь бота в группу и временно посмотри getUpdates или логи.
EXPERT_CHAT_ID=

# Обычно не нужно. Если Telegram API не открывается из Python, укажи локальный прокси.
# PROXY_URL=socks5://127.0.0.1:10808
LOG_FILE=plantcare.log
